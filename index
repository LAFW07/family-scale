<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
<title>축약형 가족관계척도</title>
<style>
:root {
  --blue: #2563eb;
  --blue-dark: #1d4ed8;
  --blue-pale: #eef4ff;
  --blue-border: #c7dafc;
  --ink: #1f2937;
  --ink-soft: #4b5563;
  --line: #e2e8f0;
  --bg: #ffffff;
  --danger: #dc2626;
  --radius: 12px;
}

* {
  box-sizing: border-box;
}

html, body {
  margin: 0;
  padding: 0;
  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Malgun Gothic",
    "Apple SD Gothic Neo", Roboto, sans-serif;
  font-size: 16px;
  line-height: 1.55;
  -webkit-tap-highlight-color: transparent;
}

.page {
  max-width: 720px;
  margin: 0 auto;
  padding: 24px 20px 64px;
}

/* ---------- Header ---------- */

.header {
  margin-bottom: 20px;
}

.title {
  font-size: 24px;
  font-weight: 700;
  color: var(--ink);
  text-align: center;
  margin: 8px 0 24px;
}

.header-fields {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}

.field {
  flex: 1 1 220px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.field label {
  font-size: 15px;
  font-weight: 600;
  color: var(--ink-soft);
}

.required {
  color: var(--danger);
}

.field input {
  height: 50px;
  padding: 0 16px;
  font-size: 16px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #fff;
  color: var(--ink);
}

.field input:focus {
  outline: none;
  border-color: var(--blue);
  box-shadow: 0 0 0 3px var(--blue-pale);
}

.field input[readonly] {
  background: #f8fafc;
  color: var(--ink-soft);
}

.field input.missing-field {
  border-color: var(--danger);
}

/* ---------- Card base ---------- */

.card {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 20px;
  margin-bottom: 20px;
}

.section-title {
  font-size: 18px;
  font-weight: 700;
  margin: 0 0 16px;
  color: var(--ink);
}

/* ---------- Legend ---------- */

.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 18px;
  background: var(--blue-pale);
  border-color: var(--blue-border);
}

.legend-item {
  font-size: 15px;
  color: var(--ink-soft);
  white-space: nowrap;
}

.legend-num {
  color: var(--blue-dark);
  font-weight: 700;
  margin-right: 2px;
}

/* ---------- Question cards ---------- */

.question-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 20px;
}

.q-card {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 20px;
  transition: border-color 0.15s ease;
}

.q-card.missing {
  border-color: var(--danger);
}

.q-head {
  display: flex;
  gap: 10px;
  align-items: baseline;
  margin-bottom: 16px;
}

.q-num {
  flex: none;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: var(--blue-pale);
  color: var(--blue-dark);
  font-weight: 700;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.q-text {
  font-size: 16px;
  font-weight: 600;
  color: var(--ink);
}

.q-options {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8px;
}

.opt-btn {
  height: 50px;
  min-width: 50px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: #fff;
  color: var(--ink-soft);
  font-size: 20px;
  cursor: pointer;
  transition: background 0.12s ease, border-color 0.12s ease, color 0.12s ease;
}

.opt-btn:active {
  transform: scale(0.98);
}

.opt-btn.selected {
  background: var(--blue);
  border-color: var(--blue);
  color: #fff;
}

/* ---------- Safety score ---------- */

.safety-card {
  border-color: var(--line);
}

.safety-scale {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8px;
}

.safety-btn {
  height: 54px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: #fff;
  color: var(--ink-soft);
  font-size: 18px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.12s ease, border-color 0.12s ease, color 0.12s ease;
}

.safety-btn.selected {
  background: var(--blue);
  border-color: var(--blue);
  color: #fff;
}

.safety-card.missing {
  border-color: var(--danger);
}

/* ---------- Reason ---------- */

.reason-card textarea {
  width: 100%;
  min-height: 4.8em;
  padding: 14px 16px;
  font-size: 16px;
  font-family: inherit;
  line-height: 1.5;
  color: var(--ink);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  resize: none;
  overflow: hidden;
}

.reason-card textarea:focus {
  outline: none;
  border-color: var(--blue);
  box-shadow: 0 0 0 3px var(--blue-pale);
}

/* ---------- Calculate button ---------- */

.calc-btn {
  display: block;
  width: 100%;
  height: 58px;
  font-size: 18px;
  font-weight: 700;
  color: #fff;
  background: var(--blue);
  border: none;
  border-radius: var(--radius);
  cursor: pointer;
  transition: background 0.12s ease;
}

.calc-btn:hover {
  background: var(--blue-dark);
}

.calc-btn:active {
  transform: scale(0.99);
}

/* ---------- Result ---------- */

.result-card {
  margin-top: 20px;
  background: var(--blue-pale);
  border-color: var(--blue-border);
}

.result-card.hidden {
  display: none;
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--blue-border);
}

.result-row:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 16px;
  font-weight: 600;
  color: var(--ink-soft);
}

.result-value {
  font-size: 26px;
  font-weight: 700;
  color: var(--blue-dark);
}

.save-btn {
  display: block;
  width: 100%;
  height: 50px;
  margin-top: 16px;
  font-size: 16px;
  font-weight: 700;
  color: var(--blue-dark);
  background: #fff;
  border: 1.5px solid var(--blue);
  border-radius: 10px;
  cursor: pointer;
  transition: background 0.12s ease;
}

.save-btn:hover {
  background: var(--blue-pale);
}

.save-btn:active {
  transform: scale(0.99);
}

/* ---------- Modal ---------- */

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  z-index: 100;
}

.modal-overlay.hidden {
  display: none;
}

.modal {
  background: #fff;
  border-radius: var(--radius);
  padding: 24px;
  max-width: 360px;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 17px;
  font-weight: 700;
  margin: 0 0 14px;
  color: var(--ink);
}

.modal-list {
  margin: 0 0 20px;
  padding-left: 20px;
  color: var(--ink-soft);
  font-size: 15px;
}

.modal-list li {
  margin-bottom: 6px;
}

.modal-btn {
  display: block;
  width: 100%;
  height: 50px;
  font-size: 16px;
  font-weight: 700;
  color: #fff;
  background: var(--blue);
  border: none;
  border-radius: 10px;
  cursor: pointer;
}

.modal-btn:hover {
  background: var(--blue-dark);
}

/* ---------- Responsive ---------- */

@media (max-width: 480px) {
  .page {
    padding: 16px 14px 48px;
  }

  .title {
    font-size: 21px;
  }

  .q-options,
  .safety-scale {
    gap: 6px;
  }

  .opt-btn {
    font-size: 17px;
    height: 48px;
  }

  .safety-btn {
    height: 48px;
    font-size: 16px;
  }
}

@media (min-width: 700px) {
  .safety-scale {
    grid-template-columns: repeat(10, 1fr);
  }
}

</style>
</head>
<body>

<div class="page">

  <!-- Header -->
  <header class="header">
    <h1 class="title">축약형 가족관계척도</h1>

    <div class="header-fields">
      <div class="field">
        <label for="subjectName">대상자명 <span class="required">*</span></label>
        <input type="text" id="subjectName" placeholder="이름을 입력해주세요" autocomplete="off">
      </div>
      <div class="field">
        <label for="testDate">검사일</label>
        <input type="text" id="testDate" readonly>
      </div>
    </div>
  </header>

  <!-- Scale legend (shown once) -->
  <section class="legend card">
    <div class="legend-item"><span class="legend-num">①</span> 전혀 그렇지 않다</div>
    <div class="legend-item"><span class="legend-num">②</span> 대체로 그렇지 않다</div>
    <div class="legend-item"><span class="legend-num">③</span> 보통이다</div>
    <div class="legend-item"><span class="legend-num">④</span> 대체로 그렇다</div>
    <div class="legend-item"><span class="legend-num">⑤</span> 항상 그렇다</div>
  </section>

  <!-- Question cards -->
  <section id="questionList" class="question-list"></section>

  <!-- Safety score -->
  <section class="card safety-card" id="safetySection">
    <h2 class="section-title">우리 집의 안전점수</h2>
    <div class="safety-scale" id="safetyScale"></div>
  </section>

  <!-- Reason -->
  <section class="card reason-card">
    <h2 class="section-title">그렇게 생각한 이유</h2>
    <textarea id="reasonText" placeholder="자유롭게 작성해주세요." rows="3"></textarea>
  </section>

  <!-- Calculate button -->
  <button id="calcBtn" class="calc-btn">결과 계산</button>

  <!-- Result -->
  <section id="resultSection" class="card result-card hidden">
    <h2 class="section-title">결과</h2>
    <div class="result-row">
      <span class="result-label">평균</span>
      <span class="result-value" id="resultAvg">-</span>
    </div>
    <div class="result-row">
      <span class="result-label">안전점수</span>
      <span class="result-value" id="resultSafety">-</span>
    </div>
    <button id="saveResultBtn" class="save-btn" type="button">PNG로 저장</button>
  </section>

</div>

<!-- Missing-field modal -->
<div id="missingModal" class="modal-overlay hidden">
  <div class="modal">
    <p class="modal-title">응답하지 않은 항목이 있습니다.</p>
    <ul id="missingList" class="modal-list"></ul>
    <button id="modalConfirm" class="modal-btn">확인</button>
  </div>
</div>

<script>
(function () {
  "use strict";

  // 15 items — exact wording from the source scale, unmodified.
  var QUESTIONS = [
    "우리 가족은 가족끼리 대화가 잘 된다.",
    "우리 가족은 문제를 함께 잘 해결하려고 노력한다.",
    "우리 가족은 서로에 대해 잘 알고 있다.",
    "우리 가족은 각자의 장점에 대해 가족들에게 마음을 열고 허심탄회하게 이야기한다.",
    "우리 가족은 도움이 필요할 때 언제든지 서로 도움을 청할 수 있다.",
    "우리 가족은 여가시간을 함께 보내기를 좋아한다.",
    "우리 가족은 서로 친말하게 느낀다.",
    "우리 가족은 솔직하고 정직하다.",
    "우리 가족은 서로 지지해주고 격려해준다.",
    "우리 가족은 서로에게 생각과 느낌을 표현할 수 있다.",
    "가족의 일을 계획할 때 우리 가족 모두에게 발언권이 있다.",
    "우리 가족은 서로를 있는 그대로 인정한다.",
    "우리 가족은 각각 자신의 행동에 책임을 진다.",
    "우리 가족은 가족들 간의 서로 다른 의견을 존중한다.",
    "우리 가족은 서로의 강점을 존중한다."
  ];

  var CIRCLED = ["①", "②", "③", "④", "⑤"];

  var answers = new Array(QUESTIONS.length).fill(null);
  var safetyScore = null;

  var questionListEl = document.getElementById("questionList");
  var safetyScaleEl = document.getElementById("safetyScale");
  var safetySectionEl = document.getElementById("safetySection");
  var subjectNameEl = document.getElementById("subjectName");
  var testDateEl = document.getElementById("testDate");
  var reasonTextEl = document.getElementById("reasonText");
  var calcBtn = document.getElementById("calcBtn");
  var resultSection = document.getElementById("resultSection");
  var resultAvgEl = document.getElementById("resultAvg");
  var resultSafetyEl = document.getElementById("resultSafety");
  var missingModal = document.getElementById("missingModal");
  var missingList = document.getElementById("missingList");
  var modalConfirm = document.getElementById("modalConfirm");
  var saveResultBtn = document.getElementById("saveResultBtn");

  var firstMissingEl = null;
  var calculated = false;

  function pad(n) {
    return n < 10 ? "0" + n : "" + n;
  }

  function setTodayDate() {
    var d = new Date();
    testDateEl.value = d.getFullYear() + "." + pad(d.getMonth() + 1) + "." + pad(d.getDate());
  }

  function renderQuestions() {
    QUESTIONS.forEach(function (text, index) {
      var card = document.createElement("div");
      card.className = "q-card";
      card.id = "q-card-" + index;

      var head = document.createElement("div");
      head.className = "q-head";

      var num = document.createElement("span");
      num.className = "q-num";
      num.textContent = index + 1;

      var qtext = document.createElement("span");
      qtext.className = "q-text";
      qtext.textContent = text;

      head.appendChild(num);
      head.appendChild(qtext);

      var options = document.createElement("div");
      options.className = "q-options";

      CIRCLED.forEach(function (symbol, optIndex) {
        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "opt-btn";
        btn.textContent = symbol;
        btn.setAttribute("aria-label", (index + 1) + "번 문항 " + (optIndex + 1) + "점");
        btn.addEventListener("click", function () {
          selectAnswer(index, optIndex, options);
        });
        options.appendChild(btn);
      });

      card.appendChild(head);
      card.appendChild(options);
      questionListEl.appendChild(card);
    });
  }

  function selectAnswer(qIndex, optIndex, optionsContainer) {
    answers[qIndex] = optIndex + 1;
    var buttons = optionsContainer.querySelectorAll(".opt-btn");
    buttons.forEach(function (b, i) {
      b.classList.toggle("selected", i === optIndex);
    });
    document.getElementById("q-card-" + qIndex).classList.remove("missing");
    if (calculated) {
      calcBtn.textContent = "결과 계산";
      calculated = false;
      resultSection.classList.add("hidden");
    }
  }

  function renderSafetyScale() {
    for (var i = 1; i <= 10; i++) {
      (function (value) {
        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "safety-btn";
        btn.textContent = value;
        btn.setAttribute("aria-label", "안전점수 " + value);
        btn.addEventListener("click", function () {
          safetyScore = value;
          var buttons = safetyScaleEl.querySelectorAll(".safety-btn");
          buttons.forEach(function (b) {
            b.classList.toggle("selected", b === btn);
          });
          safetySectionEl.classList.remove("missing");
          if (calculated) {
            calcBtn.textContent = "결과 계산";
            calculated = false;
            resultSection.classList.add("hidden");
          }
        });
        safetyScaleEl.appendChild(btn);
      })(i);
    }
  }

  function autoGrowTextarea() {
    reasonTextEl.style.height = "auto";
    reasonTextEl.style.height = reasonTextEl.scrollHeight + "px";
  }

  function clearFieldError() {
    subjectNameEl.classList.remove("missing-field");
    if (calculated) {
      calcBtn.textContent = "결과 계산";
      calculated = false;
      resultSection.classList.add("hidden");
    }
  }

  function validate() {
    var missing = [];
    firstMissingEl = null;

    QUESTIONS.forEach(function (t, i) {
      var card = document.getElementById("q-card-" + i);
      if (answers[i] === null) {
        missing.push((i + 1) + "번 문항");
        card.classList.add("missing");
        if (!firstMissingEl) firstMissingEl = card;
      } else {
        card.classList.remove("missing");
      }
    });

    if (!subjectNameEl.value.trim()) {
      missing.push("대상자명");
      subjectNameEl.classList.add("missing-field");
      if (!firstMissingEl) firstMissingEl = subjectNameEl;
    } else {
      subjectNameEl.classList.remove("missing-field");
    }

    if (safetyScore === null) {
      missing.push("안전점수를 선택해주세요.");
      safetySectionEl.classList.add("missing");
      if (!firstMissingEl) firstMissingEl = safetySectionEl;
    } else {
      safetySectionEl.classList.remove("missing");
    }

    return missing;
  }

  function showMissingModal(missing) {
    missingList.innerHTML = "";
    missing.forEach(function (m) {
      var li = document.createElement("li");
      li.textContent = m;
      missingList.appendChild(li);
    });
    missingModal.classList.remove("hidden");
  }

  function hideMissingModal() {
    missingModal.classList.add("hidden");
    if (firstMissingEl) {
      firstMissingEl.scrollIntoView({ behavior: "smooth", block: "center" });
      if (typeof firstMissingEl.focus === "function") {
        firstMissingEl.focus({ preventScroll: true });
      }
    }
  }

  function calculate() {
    var missing = validate();
    if (missing.length > 0) {
      showMissingModal(missing);
      return;
    }

    var sum = answers.reduce(function (a, b) {
      return a + b;
    }, 0);
    var avg = (sum / QUESTIONS.length).toFixed(2);

    resultAvgEl.textContent = avg;
    resultSafetyEl.textContent = safetyScore;
    resultSection.classList.remove("hidden");

    calcBtn.textContent = "다시 계산";
    calculated = true;

    resultSection.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  // ---- PNG export (canvas-based, no external libraries) ----

  var KO_FONT = "'Malgun Gothic', 'Apple SD Gothic Neo', sans-serif";

  function wrapLines(ctx, text, maxWidth) {
    var words = text.split(" ");
    var lines = [];
    var current = "";
    words.forEach(function (w) {
      var test = current ? current + " " + w : w;
      if (ctx.measureText(test).width > maxWidth && current) {
        lines.push(current);
        current = w;
      } else {
        current = test;
      }
    });
    if (current) lines.push(current);
    return lines;
  }

  function generateResultCanvas() {
    var WIDTH = 880;
    var MARGIN = 40;
    var CONTENT_W = WIDTH - MARGIN * 2;
    var LINE_H = 22;
    var ROW_GAP = 10;

    var canvas = document.createElement("canvas");
    var ctx = canvas.getContext("2d");

    var reasonValue = reasonTextEl.value.trim();

    // Pass 1: measure
    ctx.font = "15px " + KO_FONT;
    var qLines = QUESTIONS.map(function (q) {
      return wrapLines(ctx, q, CONTENT_W - 150);
    });
    var reasonLines = reasonValue ? wrapLines(ctx, reasonValue, CONTENT_W) : [];

    var y = MARGIN + 34 + 26 + 20 + 26;
    qLines.forEach(function (lines) {
      y += Math.max(lines.length, 1) * LINE_H + ROW_GAP;
    });
    y += 10 + 40;
    if (reasonValue) {
      y += 26 + reasonLines.length * LINE_H + 20;
    }
    y += 6 + 74 + 20 + 20;

    canvas.width = WIDTH;
    canvas.height = y;

    // Pass 2: draw
    ctx.fillStyle = "#ffffff";
    ctx.fillRect(0, 0, WIDTH, canvas.height);
    ctx.textBaseline = "top";

    var cy = MARGIN;

    ctx.font = "bold 26px " + KO_FONT;
    ctx.fillStyle = "#1f2937";
    ctx.fillText("축약형 가족관계척도 결과", MARGIN, cy);
    cy += 34;

    ctx.font = "15px " + KO_FONT;
    ctx.fillStyle = "#4b5563";
    ctx.fillText(
      "대상자명: " + (subjectNameEl.value.trim() || "-") + "     검사일: " + testDateEl.value,
      MARGIN,
      cy
    );
    cy += 26;

    ctx.strokeStyle = "#e2e8f0";
    ctx.beginPath();
    ctx.moveTo(MARGIN, cy);
    ctx.lineTo(WIDTH - MARGIN, cy);
    ctx.stroke();
    cy += 20;

    ctx.font = "bold 17px " + KO_FONT;
    ctx.fillStyle = "#1f2937";
    ctx.fillText("문항 응답", MARGIN, cy);
    cy += 26;

    QUESTIONS.forEach(function (q, i) {
      var lines = qLines[i];
      var rowH = Math.max(lines.length, 1) * LINE_H;

      ctx.font = "bold 15px " + KO_FONT;
      ctx.fillStyle = "#2563eb";
      ctx.fillText((i + 1) + ".", MARGIN, cy);

      ctx.font = "15px " + KO_FONT;
      ctx.fillStyle = "#1f2937";
      lines.forEach(function (line, li) {
        ctx.fillText(line, MARGIN + 28, cy + li * LINE_H);
      });

      ctx.font = "bold 16px " + KO_FONT;
      ctx.fillStyle = "#2563eb";
      var ans = answers[i] ? CIRCLED[answers[i] - 1] : "-";
      ctx.fillText(ans, WIDTH - MARGIN - 24, cy);

      cy += rowH + ROW_GAP;
    });

    cy += 10;
    ctx.strokeStyle = "#e2e8f0";
    ctx.beginPath();
    ctx.moveTo(MARGIN, cy);
    ctx.lineTo(WIDTH - MARGIN, cy);
    ctx.stroke();
    cy += 20;

    ctx.font = "bold 17px " + KO_FONT;
    ctx.fillStyle = "#1f2937";
    ctx.fillText("우리 집의 안전점수", MARGIN, cy);
    ctx.font = "bold 20px " + KO_FONT;
    ctx.fillStyle = "#2563eb";
    ctx.fillText(String(safetyScore), WIDTH - MARGIN - 20, cy - 2);
    cy += 40;

    if (reasonValue) {
      ctx.font = "bold 17px " + KO_FONT;
      ctx.fillStyle = "#1f2937";
      ctx.fillText("그렇게 생각한 이유", MARGIN, cy);
      cy += 26;
      ctx.font = "15px " + KO_FONT;
      ctx.fillStyle = "#4b5563";
      reasonLines.forEach(function (line, li) {
        ctx.fillText(line, MARGIN, cy + li * LINE_H);
      });
      cy += reasonLines.length * LINE_H + 20;
    }

    cy += 6;
    ctx.fillStyle = "#eef4ff";
    ctx.fillRect(MARGIN, cy, CONTENT_W, 74);
    ctx.strokeStyle = "#c7dafc";
    ctx.strokeRect(MARGIN, cy, CONTENT_W, 74);

    ctx.font = "bold 15px " + KO_FONT;
    ctx.fillStyle = "#4b5563";
    ctx.fillText("평균", MARGIN + 24, cy + 16);
    ctx.font = "bold 30px " + KO_FONT;
    ctx.fillStyle = "#1d4ed8";
    ctx.fillText(resultAvgEl.textContent, MARGIN + 24, cy + 34);

    ctx.font = "bold 15px " + KO_FONT;
    ctx.fillStyle = "#4b5563";
    ctx.fillText("안전점수", MARGIN + 260, cy + 16);
    ctx.font = "bold 30px " + KO_FONT;
    ctx.fillStyle = "#1d4ed8";
    ctx.fillText(resultSafetyEl.textContent, MARGIN + 260, cy + 34);

    cy += 74 + 20;

    ctx.font = "13px " + KO_FONT;
    ctx.fillStyle = "#9ca3af";
    ctx.fillText("생성일시: " + new Date().toLocaleString("ko-KR"), MARGIN, cy);

    return canvas;
  }

  function downloadResultPNG() {
    if (!calculated) return;
    var canvas = generateResultCanvas();
    var namePart = (subjectNameEl.value.trim() || "결과").replace(/[\\/:*?"<>|]/g, "_");
    var datePart = testDateEl.value.replace(/\./g, "");
    var link = document.createElement("a");
    link.download = "가족관계척도_" + namePart + "_" + datePart + ".png";
    link.href = canvas.toDataURL("image/png");
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  // ---- init ----
  setTodayDate();
  renderQuestions();
  renderSafetyScale();

  reasonTextEl.addEventListener("input", autoGrowTextarea);
  autoGrowTextarea();

  subjectNameEl.addEventListener("input", clearFieldError);

  calcBtn.addEventListener("click", calculate);
  saveResultBtn.addEventListener("click", downloadResultPNG);
  modalConfirm.addEventListener("click", hideMissingModal);
  missingModal.addEventListener("click", function (e) {
    if (e.target === missingModal) hideMissingModal();
  });
})();

</script>
</body>
</html>
